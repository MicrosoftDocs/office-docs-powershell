{
  "build": {
    "content": [
      {
        "files": [
          "**/*.md",
          "**/*.yml"
        ],
        "src": "docs-conceptual",
        "version": "inkcanvas-ps",
        "dest": "inkcanvas",
        "exclude": [
          "**/obj/**",
          "**/includes/**",
          "README.md",
          "LICENSE",
          "LICENSE-CODE",
          "ThirdPartyNotices",
          "ThirdPartyNotices.md"
        ]
      },
      {
        "files": [
          "toc.yml",
          "**/*.md",
          "**/*.yml"
        ],
        "src": "docs-conceptual",
        "version": "inkcanvas-ps",
        "dest": "inkcanvas/inkcanvas-ps"
      },
      {
        "files": [
          "**/*.yml"
        ],
        "exclude": [
          "toc.yml"
        ],
        "src": "inkcanvas-ps",
        "version": "inkcanvas-ps",
        "dest": "module"
      },
      {
        "files": [
          "toc.yml"
        ],
        "src": "inkcanvas-ps",
        "version": "inkcanvas-ps",
        "dest": "module/inkcanvas-ps"
      },
      {
        "files": [
          "**/*.md"
        ],
        "src": "virtual-folder",
        "version": "inkcanvas-ps",
        "dest": "module"
      }
    ],
    "resource": [
      {
        "files": [
          "**/*.png",
          "**/*.jpg"
        ],
        "exclude": [
          "**/obj/**",
          "**/includes/**"
        ]
      }
    ],
    "versions": {
      "inkcanvas-ps": {
        "dest": "inkcanvas-ps"
      }
    },
    "overwrite": [],
    "externalReference": [],
    "globalMetadata": {
      "uhfHeaderId": "MSDocsHeader-M365-IT",
      "ms.topic": "reference",
      "ms.devlang": "powershell",
      "feedback_system": "Standard",
      "feedback_product_url": "https://github.com/MicrosoftDocs/office-docs-powershell/issues"
    },
    "contributors_to_exclude": [
      "aditisrivastava07",
      "AGuentherinWA",
      "claydetels19",
      "dstrome",
      "garycentric",
      "padmagit77",
      "rjagiewich",
      "Ruchika-mittal01",
      "Shipra-M09",
      "techtoons"
    ],
    "fileMetadata": {},
    "template": [],
    "dest": "inkcanvas-ps",
    "rules": {
        "filename-incomplete": {
            "exclude": [
                "**/*.md",
                "**/*.yml"
            ]
        },
        "image-name-incomplete": {
            "exclude": [
                "**/*.gif",
                "**/*.jpeg",
                "**/*.jpg",
                "**/*.png",
                "**/*.svg"
            ]
        },
        "image-structure-incorrect": {
            "exclude": [
                "**/*.gif",
                "**/*.jpeg",
                "**/*.jpg",
                "**/*.png",
                "**/*.svg"
            ]
        },
        "include-structure-incorrect": {
            "exclude": [
                "**/*.md",
                "**/*.yml"
            ]
        }
    }
  }
}
